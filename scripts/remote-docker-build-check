#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."
builder="${GPU_JOB_DOCKER_BUILDER:-netcup}"
workdir="${GPU_JOB_REMOTE_WORKDIR:-/home/admin/gpu-job-control-codex-netcup}"
rsync_args=(-az --exclude .venv --exclude __pycache__ --exclude .pytest_cache --exclude .ruff_cache)
if [ "${GPU_JOB_REMOTE_RSYNC_DELETE:-0}" = "1" ]; then
  rsync_args+=(--delete)
fi
rsync "${rsync_args[@]}" ./ "$builder:$workdir/"
ssh "$builder" "
  set -euo pipefail
  cd '$workdir'
  if docker buildx version >/dev/null 2>&1 && docker build --help | grep -q -- "--check"; then
    docker build --check -f docker/asr-worker.Dockerfile .
  else
    awk 'BEGIN{bad=0}
      /^FROM /{from++}
      /^RUN /{run++}
      /^COPY /{copy++}
      /^ENTRYPOINT /{entry++}
      END{
        print "from=" from, "run=" run, "copy=" copy, "entrypoint=" entry;
        if(!from || !entry) bad=1;
        exit bad
      }' docker/asr-worker.Dockerfile
  fi
"
