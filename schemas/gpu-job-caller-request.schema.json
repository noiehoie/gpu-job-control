{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/noiehoie/gpu-job-control/blob/main/schemas/gpu-job-caller-request.schema.json",
  "title": "gpu-job-control canonical caller request",
  "description": "Deterministic caller-facing request contract compiled into the internal gpu-job job shape.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "operation",
    "input",
    "output_expectation",
    "limits",
    "idempotency",
    "caller"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "gpu-job-caller-request-v1"
    },
    "operation": {
      "type": "string",
      "description": "Closed operation identifier from config/operation-catalog.json."
    },
    "input": {
      "type": "object",
      "additionalProperties": true,
      "required": ["uri"],
      "properties": {
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "content_type": {
          "type": "string"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "output_expectation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_uri", "required_files"],
      "properties": {
        "target_uri": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string"
        },
        "required_files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_runtime_minutes", "max_cost_usd", "max_output_gb"],
      "properties": {
        "max_runtime_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "max_cost_usd": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "max_output_gb": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "idempotency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key"],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "caller": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "operation", "request_id", "version"],
      "properties": {
        "system": {
          "type": "string",
          "minLength": 1
        },
        "operation": {
          "type": "string",
          "minLength": 1
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "trace_context": {
      "type": "object",
      "additionalProperties": true
    },
    "preferences": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": ["string", "null"]
        },
        "gpu_profile": {
          "type": "string",
          "minLength": 1
        },
        "worker_image": {
          "type": "string",
          "minLength": 1
        },
        "provider_module_id": {
          "type": "string",
          "minLength": 1
        },
        "quality_requires_gpu": {
          "type": "boolean"
        },
        "allow_quality_downgrade": {
          "type": "boolean"
        }
      }
    }
  }
}
