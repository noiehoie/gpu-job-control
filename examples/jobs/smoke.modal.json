{
  "job_type": "smoke",
  "input_uri": "none://modal-gpu-smoke",
  "output_uri": "local://modal-gpu-smoke",
  "worker_image": "modal:function:gpu-job-modal-smoke",
  "gpu_profile": "asr_fast",
  "model": "nvidia-smi",
  "limits": {
    "max_runtime_minutes": 10,
    "max_cost_usd": 2,
    "max_output_gb": 1
