{
  "job_type": "llm_heavy",
  "input_uri": "text://Say hello from a RunPod Pod GPU canary.",
  "output_uri": "local://runpod-pod-llm-heavy",
  "worker_image": "runpod/pytorch:1.0.2-cu1281-torch280-ubuntu2404",
  "gpu_profile": "llm_batch",
